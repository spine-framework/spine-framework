# Spine Framework Environment Configuration
# 
# SECURITY WARNING: Never commit real credentials to version control!
# Replace the placeholder values below with your actual Supabase credentials.
# Copy this file to .xenv and fill in your real values.

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend Configuration (for CLI and server-side operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Development Configuration
VITE_NETLIFY_FUNCTIONS_URL=http://localhost:8888
NODE_ENV=development
SCHEDULER_API_KEY=your-scheduler-api-key-here
DB_SCHEMA=public
