    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@netlify/functions": "^2.8.2",
    "@radix-ui/react-accordion": "^1.2.12",
