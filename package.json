{
  "name": "spine-framework",
  "version": "1.0.0",
  "private": false,
  "description": "Spine — enterprise application framework built on Supabase + Netlify + React",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "keywords": [
    "spine",
    "framework",
    "supabase",
    "netlify",
    "react",
    "enterprise",
    "agentic"
  ],
  "homepage": "https://github.com/spine-framework/spine-framework#readme",
  "bugs": {
    "url": "https://github.com/spine-framework/spine-framework/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/spine-framework/spine-framework.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "spine-framework": "./bin/spine-framework.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/functions/_shared/index.d.ts",
      "import": "./.framework/functions/_shared/index.ts"
    },
    "./_shared": {
      "types": "./dist/functions/_shared/index.d.ts",
      "import": "./.framework/functions/_shared/index.ts"
    },
    "./_shared/*": {
      "types": "./dist/functions/_shared/*.d.ts",
      "import": "./.framework/functions/_shared/*.ts"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./.framework/cli/index.ts"
    }
  },
  "files": [
    "bin/",
    "dist/",
    ".framework/cli/",
    ".framework/functions/",
    ".framework/migrations/",
    ".framework/docs/",
    ".framework/src/",
    "scripts/",
    "config/",
    "netlify.toml",
    "vitest.config.ts",
    "index.html",
    "package-project.json",
    "STRUCTURE.md",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "spine-framework": "tsx .framework/cli/index.ts",
    "dev": "vite --config config/vite.config.ts",
    "assemble": "bash scripts/assemble.sh",
    "assemble:frontend": "bash scripts/assemble-frontend.sh",
    "assemble:functions": "bash scripts/assemble-functions.sh",
    "manifest": "bash scripts/build-manifest.sh",
    "verify": "bash scripts/verify-integrity.sh",
    "prebuild": "npm run assemble && npm run verify",
    "build": "tsc -b config/tsconfig.json && vite build --config config/vite.config.ts",
    "build:lib": "tsc -p config/tsconfig.build.json",
    "preview": "vite preview --config config/vite.config.ts",
    "lint": "eslint .",
    "app-install": "tsx scripts/app-install.ts",
    "test": "vitest run",
    "test:unit": "vitest run .framework/tests/unit",
    "test:integration": "vitest run .framework/tests/integration",
    "postinstall": "node bin/welcome.cjs || true",
    "docs": "typedoc --config config/typedoc.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "commander": "^12.0.0",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "pg": "^8.13.0",
    "tsx": "^4.21.0",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "@netlify/functions": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.0.0",
    "vite": "^5.0.0 || ^6.0.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@tiptap/extension-code-block-lowlight": "^3.24.0",
    "@tiptap/extension-placeholder": "^3.24.0",
    "lowlight": "^3.3.0",
    "highlight.js": "^11.11.1"
  },
  "peerDependenciesMeta": {
    "@netlify/functions": {
      "optional": false
    },
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "react-router-dom": {
      "optional": false
    },
    "vite": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "@tiptap/extension-code-block-lowlight": {
      "optional": true
    },
    "@tiptap/extension-placeholder": {
      "optional": true
    },
    "lowlight": {
      "optional": true
    },
    "highlight.js": {
      "optional": true
    }
  },
