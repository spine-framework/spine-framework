{
  "name": "spine-framework",
  "version": "1.0.0",
  "description": "A comprehensive framework for building enterprise applications with multi-tenant architecture, role-based access control, and extensible app ecosystem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://spine-framework.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/spine-framework/spine-framework.git"
  },
  "keywords": [
    "spine-framework",
    "enterprise",
    "multi-tenant",
    "saas",
    "framework",
    "react",
    "typescript",
    "postgresql",
    "supabase",
    "real-time",
    "ai",
    "rbac",
    "authentication",
    "authorization"
  ],
  "author": "Dahl Ventures Inc.",
  "license": "SEE LICENSE IN LICENSE.md",
  "files": [
    "dist/**/*",
    "src/**/*",
    "LICENSE.md",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@supabase/auth-helpers-react": "^0.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "zustand": "^4.4.0",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "tailwindcss": "^3.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0",
    "commander": "^11.0.0",
    "@vitejs/plugin-react": "^4.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./contexts": {
      "types": "./dist/contexts/index.d.ts",
      "default": "./dist/contexts/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "default": "./dist/styles/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "spine": "dist/cli/index.js"
  },
  "spine": {
    "framework": {
      "version": "1.0.0",
      "compatibility": {
        "node": ">=18.0.0",
        "react": ">=18.0.0"
      }
    },
    "features": [
      "multi-tenant",
      "rbac",
      "real-time",
      "ai-integration",
      "app-registry"
    ]
  }
}
